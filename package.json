{
  "name": "erp",
  "version": "1.0.0",
  "description": "ERP backend foundation for construction domain",
  "main": "dist/index.js",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:all": "concurrently -k -n api,web -c cyan,magenta \"npm run dev\" \"npm run dev:web\"",
    "dev:token": "tsx scripts/print-dev-token.ts",
    "dev:web": "npm run dev -w apps/web",
    "build:web": "npm run build -w apps/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && npx tsc --noEmit -p apps/web/tsconfig.json",
    "postinstall": "prisma generate",
    "check:prisma-stack": "node scripts/check-prisma-stack.mjs",
    "prisma:validate": "node scripts/prisma-env-placeholder.mjs validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify:ci": "npm run audit:prod && npm audit --audit-level=high && npm run check:prisma-stack && npm run prisma:validate && npm run validate:api-contract-yaml && npm run validate:cursor-project-rules && npm run check:dunning-inventory && npm run validate:compliance-artifacts && npm run validate:compliance-signoffs && npm run typecheck && npm run build:web && npm run test -w apps/web && npm test",
    "verify:ci:with-migrate": "npx prisma migrate deploy && npm run verify:ci",
    "docker:db-up": "docker compose up -d",
    "ensure:local-test-db": "node scripts/ensure-local-postgres-test-db.mjs",
    "verify:ci:local-db": "npm run ensure:local-test-db && sh -c 'export DATABASE_URL=${DATABASE_URL:-postgresql://erp:erp@127.0.0.1:15432/erp_test} PERSISTENCE_DB_TEST_URL=${PERSISTENCE_DB_TEST_URL:-postgresql://erp:erp@127.0.0.1:15432/erp_test} && npm run verify:ci:with-migrate'",
    "verify:pre-merge": "npm run verify:ci && npx playwright test e2e/login-finance-smoke.spec.ts",
    "validate:api-contract-yaml": "node scripts/validate-api-contract-yaml.mjs",
    "validate:cursor-project-rules": "node scripts/validate-cursor-project-rules.mjs",
    "sync:cursor-stack-skills": "node scripts/sync-cursor-stack-skills.mjs",
    "check:dunning-inventory": "node scripts/inventory-dunning-cron-refs.mjs",
    "validate:compliance-artifacts": "node scripts/check-compliance-artifacts.mjs",
    "validate:compliance-signoffs": "node scripts/validate-compliance-signoffs.mjs",
    "apply:compliance-signoffs": "node scripts/apply-compliance-signoffs.mjs",
    "apply:compliance-signoffs:apply": "node scripts/apply-compliance-signoffs.mjs --apply",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "overrides": {
    "@rollup/plugin-terser@0.4.4": {
      "serialize-javascript": "7.0.5"
    },
    "@hono/node-server": "1.19.13"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "^3.0.3",
    "date-holidays": "^3.27.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "nodemailer": "^8.0.7",
    "pg": "^8.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.11",
    "concurrently": "^9.1.2",
    "prisma": "7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3"
  }
}
