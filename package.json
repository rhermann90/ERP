{
  "name": "erp",
  "version": "1.0.0",
  "description": "ERP backend foundation for construction domain",
  "main": "dist/index.js",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:all": "concurrently -k -n api,web -c cyan,magenta \"npm run dev\" \"npm run dev:web\"",
    "dev:token": "tsx scripts/print-dev-token.ts",
    "dev:web": "npm run dev -w apps/web",
    "build:web": "npm run build -w apps/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "prisma:validate": "node scripts/prisma-env-placeholder.mjs validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify:ci": "npm run audit:prod && npm audit --audit-level=high && npm run prisma:validate && npm run validate:api-contract-yaml && npm run typecheck && npm run build:web && npm run test -w apps/web && npm test",
    "verify:ci:with-migrate": "npx prisma migrate deploy && npm run verify:ci",
    "validate:api-contract-yaml": "node scripts/validate-api-contract-yaml.mjs"
  },
  "overrides": {
    "@rollup/plugin-terser@0.4.4": {
      "serialize-javascript": "7.0.5"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.0",
    "fastify": "^5.8.5",
    "nodemailer": "^8.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^6.4.17",
    "concurrently": "^9.1.2",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3"
  }
}
