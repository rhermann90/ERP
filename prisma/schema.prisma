// ADR-0003/0006: Offer + OfferVersion; ADR Inkrement 2: current_version FK (deferrable), audit_events
// ADR-0005/0004: LV §9 + Aufmass; offer_versions.lv_version_id -> lv_versions (FIN-2 Gate G5)
// ADR-0008: payment_terms_heads / payment_terms_versions (FIN-1)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Angebots-Aggregat; current_version referenziert offer_versions (tenant-gleich), FK deferrable in SQL-Migration.
model Offer {
  tenantId         String   @map("tenant_id") @db.Uuid
  id               String   @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  customerId       String   @map("customer_id") @db.Uuid
  currentVersionId String   @map("current_version_id") @db.Uuid
  createdAt        DateTime @map("created_at")
  createdBy        String   @map("created_by") @db.Uuid

  versions         OfferVersion[]    @relation("OfferVersions")
  currentVersion   OfferVersion      @relation("OfferCurrentVersion", fields: [tenantId, currentVersionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)
  supplementOffers SupplementOffer[]

  @@id([tenantId, id])
  @@map("offers")
}

model OfferVersion {
  tenantId      String    @map("tenant_id") @db.Uuid
  id            String    @db.Uuid
  offerId       String    @map("offer_id") @db.Uuid
  versionNumber Int       @map("version_number")
  status        String
  lvVersionId   String    @map("lv_version_id") @db.Uuid
  systemText    String    @map("system_text")
  editingText   String    @map("editing_text")
  createdAt     DateTime  @map("created_at")
  createdBy     String    @map("created_by") @db.Uuid
  releasedAt    DateTime? @map("released_at")

  offer                    Offer             @relation("OfferVersions", fields: [tenantId, offerId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)
  asCurrentOf              Offer[]           @relation("OfferCurrentVersion")
  lvVersion                LvVersion         @relation(fields: [tenantId, lvVersionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)
  supplementOffersAsBase   SupplementOffer[] @relation("SupplementBaseOfferVersion")

  @@id([tenantId, id])
  @@unique([tenantId, offerId, versionNumber])
  @@index([tenantId, status])
  @@map("offer_versions")
}

model LvCatalog {
  tenantId           String      @map("tenant_id") @db.Uuid
  id                 String      @db.Uuid
  projectId          String?     @map("project_id") @db.Uuid
  name               String
  currentVersionId   String      @map("current_version_id") @db.Uuid
  createdAt          DateTime    @map("created_at")
  createdBy          String      @map("created_by") @db.Uuid

  versions       LvVersion[] @relation("LvCatalogVersions")
  currentVersion LvVersion   @relation("LvCatalogCurrentVersion", fields: [tenantId, currentVersionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)

  @@id([tenantId, id])
  @@map("lv_catalogs")
}

model LvVersion {
  tenantId           String   @map("tenant_id") @db.Uuid
  id                 String   @db.Uuid
  lvCatalogId        String   @map("lv_catalog_id") @db.Uuid
  versionNumber      Int      @map("version_number")
  status             String
  headerSystemText   String   @map("header_system_text")
  headerEditingText  String   @map("header_editing_text")
  createdAt          DateTime @map("created_at")
  createdBy          String   @map("created_by") @db.Uuid

  catalog           LvCatalog         @relation("LvCatalogVersions", fields: [tenantId, lvCatalogId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)
  catalogsCurrentOf LvCatalog[]       @relation("LvCatalogCurrentVersion")
  structureNodes    LvStructureNode[]
  positions         LvPosition[]
  offerVersions       OfferVersion[]
  measurements        Measurement[]
  supplementVersions  SupplementVersion[]

  @@id([tenantId, id])
  @@unique([tenantId, lvCatalogId, versionNumber])
  @@map("lv_versions")
}

model SupplementOffer {
  tenantId             String   @map("tenant_id") @db.Uuid
  id                   String   @db.Uuid
  offerId              String   @map("offer_id") @db.Uuid
  baseOfferVersionId   String   @map("base_offer_version_id") @db.Uuid
  createdAt            DateTime @map("created_at")
  createdBy            String   @map("created_by") @db.Uuid

  offer             Offer            @relation(fields: [tenantId, offerId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)
  baseOfferVersion  OfferVersion     @relation("SupplementBaseOfferVersion", fields: [tenantId, baseOfferVersionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)
  versions          SupplementVersion[]

  @@id([tenantId, id])
  @@map("supplement_offers")
}

model SupplementVersion {
  tenantId            String   @map("tenant_id") @db.Uuid
  id                  String   @db.Uuid
  supplementOfferId   String   @map("supplement_offer_id") @db.Uuid
  versionNumber       Int      @map("version_number")
  status              String
  lvVersionId         String   @map("lv_version_id") @db.Uuid
  systemText          String   @map("system_text")
  editingText         String   @map("editing_text")
  createdAt           DateTime @map("created_at")
  createdBy           String   @map("created_by") @db.Uuid

  supplementOffer SupplementOffer @relation(fields: [tenantId, supplementOfferId], references: [tenantId, id], onUpdate: Restrict, onDelete: Cascade)
  lvVersion       LvVersion       @relation(fields: [tenantId, lvVersionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)

  @@id([tenantId, id])
  @@unique([tenantId, supplementOfferId, versionNumber])
  @@index([tenantId, status])
  @@map("supplement_versions")
}

model LvStructureNode {
  tenantId     String  @map("tenant_id") @db.Uuid
  id           String  @db.Uuid
  lvVersionId  String  @map("lv_version_id") @db.Uuid
  parentNodeId String? @map("parent_node_id") @db.Uuid
  kind         String
  sortOrdinal  String  @map("sort_ordinal")
  systemText   String  @map("system_text")
  editingText  String  @map("editing_text")

  lvVersion LvVersion @relation(fields: [tenantId, lvVersionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Cascade)
  parent    LvStructureNode? @relation("LvNodeHierarchy", fields: [tenantId, parentNodeId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)
  children  LvStructureNode[] @relation("LvNodeHierarchy")

  positionsAsParent LvPosition[]

  @@id([tenantId, id])
  @@index([tenantId, lvVersionId])
  @@map("lv_structure_nodes")
}

model LvPosition {
  tenantId           String  @map("tenant_id") @db.Uuid
  id                 String  @db.Uuid
  lvVersionId        String  @map("lv_version_id") @db.Uuid
  parentNodeId       String  @map("parent_node_id") @db.Uuid
  sortOrdinal        String  @map("sort_ordinal")
  quantity           Float
  unit               String
  unitPriceCents     Int     @map("unit_price_cents")
  kind               String
  systemText         String  @map("system_text")
  editingText        String  @map("editing_text")
  stammPositionsRef  String? @map("stamm_positions_ref") @db.Uuid

  lvVersion  LvVersion       @relation(fields: [tenantId, lvVersionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Cascade)
  parentNode LvStructureNode @relation(fields: [tenantId, parentNodeId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)

  measurementPositions MeasurementPosition[]

  @@id([tenantId, id])
  @@index([tenantId, lvVersionId])
  @@map("lv_positions")
}

model Measurement {
  tenantId           String   @map("tenant_id") @db.Uuid
  id                 String   @db.Uuid
  projectId          String   @map("project_id") @db.Uuid
  customerId         String   @map("customer_id") @db.Uuid
  lvVersionId        String   @map("lv_version_id") @db.Uuid
  currentVersionId   String   @map("current_version_id") @db.Uuid
  createdAt          DateTime @map("created_at")
  createdBy          String   @map("created_by") @db.Uuid

  lvVersion      LvVersion             @relation(fields: [tenantId, lvVersionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)
  versions       MeasurementVersion[] @relation("MeasurementVersions")
  currentVersion MeasurementVersion   @relation("MeasurementCurrentVersion", fields: [tenantId, currentVersionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)

  @@id([tenantId, id])
  @@map("measurements")
}

model MeasurementVersion {
  tenantId       String   @map("tenant_id") @db.Uuid
  id             String   @db.Uuid
  measurementId  String   @map("measurement_id") @db.Uuid
  versionNumber  Int      @map("version_number")
  status         String
  createdAt      DateTime @map("created_at")
  createdBy      String   @map("created_by") @db.Uuid

  measurement Measurement @relation("MeasurementVersions", fields: [tenantId, measurementId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)
  asCurrentOf Measurement[] @relation("MeasurementCurrentVersion")
  positions   MeasurementPosition[]

  @@id([tenantId, id])
  @@unique([tenantId, measurementId, versionNumber])
  @@map("measurement_versions")
}

model MeasurementPosition {
  tenantId               String  @map("tenant_id") @db.Uuid
  id                     String  @db.Uuid
  measurementVersionId String  @map("measurement_version_id") @db.Uuid
  lvPositionId           String  @map("lv_position_id") @db.Uuid
  quantity               Float
  unit                   String
  note                   String?

  measurementVersion MeasurementVersion @relation(fields: [tenantId, measurementVersionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Cascade)
  lvPosition         LvPosition         @relation(fields: [tenantId, lvPositionId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)

  @@id([tenantId, id])
  @@index([tenantId, measurementVersionId])
  @@map("measurement_positions")
}


/// FIN-1 (8.5): ein Kopf pro Projekt, append-only Versionszeilen.
model PaymentTermsHead {
  tenantId    String   @map("tenant_id") @db.Uuid
  id          String   @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  createdAt   DateTime @map("created_at")
  createdBy   String   @map("created_by") @db.Uuid

  versions PaymentTermsVersion[]

  @@id([tenantId, id])
  @@unique([tenantId, projectId])
  @@map("payment_terms_heads")
}

model PaymentTermsVersion {
  tenantId      String   @map("tenant_id") @db.Uuid
  id            String   @db.Uuid
  headId        String   @map("head_id") @db.Uuid
  versionNumber Int      @map("version_number")
  termsLabel    String   @map("terms_label")
  createdAt     DateTime @map("created_at")
  createdBy     String   @map("created_by") @db.Uuid

  head PaymentTermsHead @relation(fields: [tenantId, headId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)

  @@id([tenantId, id])
  @@unique([tenantId, headId, versionNumber])
  @@index([tenantId, headId])
  @@map("payment_terms_versions")
}


/// FIN-2: Rechnung; optionale Referenz auf Zahlungsbedingungs-Version (FIN-1).
model Invoice {
  tenantId                String   @map("tenant_id") @db.Uuid
  id                      String   @db.Uuid
  projectId               String   @map("project_id") @db.Uuid
  customerId              String   @map("customer_id") @db.Uuid
  measurementId           String   @map("measurement_id") @db.Uuid
  lvId                    String   @map("lv_id") @db.Uuid
  offerId                 String   @map("offer_id") @db.Uuid
  offerVersionId          String?  @map("offer_version_id") @db.Uuid
  status                  String
  immutableFromStatus     String   @map("immutable_from_status")
  invoiceNumber           String?  @map("invoice_number")
  issueDate               String?  @map("issue_date")
  totalGrossCents         Int?     @map("total_gross_cents")
  lvNetCents              Int?     @map("lv_net_cents")
  vatCents                Int?     @map("vat_cents")
  supplementOfferId       String?  @map("supplement_offer_id") @db.Uuid
  supplementVersionId     String?  @map("supplement_version_id") @db.Uuid
  paymentTermsVersionId   String?  @map("payment_terms_version_id") @db.Uuid
  // B2-1a / 8.4(2): Skonto in Basispunkten (0–10_000) auf LV-Netto nach Schritt 1 vor USt.
  skontoBps                 Int      @default(0) @map("skonto_bps")

  paymentIntakes PaymentIntake[]
  dunningReminders DunningReminder[]
  dunningEmailSends DunningEmailSend[]

  @@id([tenantId, id])
  @@index([tenantId, projectId])
  /// Gebuchte Rechnungsnummern je Mandant eindeutig (NULL fuer Entwuerfe ohne Nummer — Postgres erlaubt mehrere NULLs).
  @@unique([tenantId, invoiceNumber], map: "invoices_tenant_invoice_number_key")
  @@map("invoices")
}

/// FIN-3: Zahlungseingang; Idempotenz (tenant_id, idempotency_key).
model PaymentIntake {
  tenantId          String   @map("tenant_id") @db.Uuid
  id                String   @db.Uuid
  invoiceId         String   @map("invoice_id") @db.Uuid
  idempotencyKey    String   @map("idempotency_key") @db.Uuid
  amountCents       Int      @map("amount_cents")
  externalReference String   @map("external_reference")
  createdAt         DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [tenantId, invoiceId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)

  @@id([tenantId, id])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, invoiceId])
  @@map("payment_intakes")
}

/// FIN-4 Kern: Mandantenspezifische Mahnstufen-Metadaten (`docs/adr/0009-fin4-mahnwesen-slice.md`). 9 aktive Zeilen (`deleted_at` null) → GET `TENANT_DATABASE`, sonst MVP-Fallback.
model DunningTenantStageConfig {
  tenantId     String    @map("tenant_id") @db.Uuid
  stageOrdinal Int       @map("stage_ordinal")
  daysAfterDue Int       @map("days_after_due")
  feeCents     Int       @map("fee_cents")
  label        String    @map("label") @db.VarChar(200)
  deletedAt    DateTime? @map("deleted_at")

  @@id([tenantId, stageOrdinal])
  @@index([tenantId, deletedAt])
  @@map("dunning_tenant_stage_config")
}

/// FIN-4 / M4: Mahn-Vorlagen je Mandant, Stufe und Kanal (Slice 1 — Lesepfad; §8.10). `docs/adr/0010-fin4-m4-dunning-email-and-templates.md`.
model DunningTenantStageTemplate {
  tenantId     String    @map("tenant_id") @db.Uuid
  stageOrdinal Int       @map("stage_ordinal")
  channel      String    @map("channel") @db.VarChar(10)
  templateType String    @map("template_type") @db.VarChar(32)
  body         String    @map("body") @db.Text
  deletedAt    DateTime? @map("deleted_at")

  @@id([tenantId, stageOrdinal, channel])
  @@index([tenantId, deletedAt])
  @@map("dunning_tenant_stage_templates")
}

/// FIN-4 / M4 Slice 3: Mandanten-Impressum für Mahn-E-Mail-Footer (§8.10), eine Zeile pro Mandant. `docs/adr/0010-fin4-m4-dunning-email-and-templates.md`.
model DunningTenantEmailFooter {
  tenantId            String @id @map("tenant_id") @db.Uuid
  companyLegalName    String @default("") @map("company_legal_name") @db.VarChar(300)
  streetLine          String @default("") @map("street_line") @db.VarChar(300)
  postalCode          String @default("") @map("postal_code") @db.VarChar(20)
  city                String @default("") @map("city") @db.VarChar(120)
  countryCode         String @default("DE") @map("country_code") @db.VarChar(2)
  publicEmail         String @default("") @map("public_email") @db.VarChar(320)
  publicPhone         String @default("") @map("public_phone") @db.VarChar(80)
  legalRepresentative String @default("") @map("legal_representative") @db.VarChar(300)
  registerCourt       String @default("") @map("register_court") @db.VarChar(200)
  registerNumber      String @default("") @map("register_number") @db.VarChar(120)
  vatId               String @default("") @map("vat_id") @db.VarChar(32)
  signatureLine       String @default("") @map("signature_line") @db.VarChar(200)

  @@map("dunning_tenant_email_footer")
}

/// FIN-4 Mahnwesen: Mahn-Ereignis je Rechnung (Slice; siehe `docs/adr/0009-fin4-mahnwesen-slice.md`).
model DunningReminder {
  tenantId     String   @map("tenant_id") @db.Uuid
  id           String   @db.Uuid
  invoiceId  String   @map("invoice_id") @db.Uuid
  stageOrdinal Int      @map("stage_ordinal")
  note         String?  @map("note") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [tenantId, invoiceId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)

  @@id([tenantId, id])
  @@index([tenantId, invoiceId])
  @@map("dunning_reminders")
}

/// FIN-4 / M4 Slice 5a: erfolgreicher Mahn-E-Mail-Versand (Idempotenz je Mandant + Idempotency-Key). `docs/adr/0010-fin4-m4-dunning-email-and-templates.md`.
model DunningEmailSend {
  tenantId         String   @map("tenant_id") @db.Uuid
  id               String   @id @db.Uuid
  invoiceId        String   @map("invoice_id") @db.Uuid
  idempotencyKey   String   @map("idempotency_key") @db.Uuid
  stageOrdinal     Int      @map("stage_ordinal")
  recipientEmail   String   @map("recipient_email") @db.VarChar(320)
  auditEventId     String   @map("audit_event_id") @db.Uuid
  smtpMessageId    String?  @map("smtp_message_id") @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [tenantId, invoiceId], references: [tenantId, id], onUpdate: Restrict, onDelete: Restrict)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, invoiceId])
  @@map("dunning_email_sends")
}

/// FIN-4 / M4 Slice 5b-1: Idempotenz fuer Mahnlauf-EXECUTE (Mandant + Idempotency-Key). `docs/adr/0010-fin4-m4-dunning-email-and-templates.md`.
model DunningReminderRunIntent {
  id             String   @id @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  idempotencyKey String   @map("idempotency_key") @db.Uuid
  fingerprint    String   @map("fingerprint") @db.VarChar(128)
  responseJson   String   @map("response_json") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@map("dunning_reminder_run_intents")
}

/// FIN-4 / M4: Mandanten-Modus Mahnlauf (OFF | SEMI). job_hour_utc historisch (immer null). SEMI-Kontext: ADR-0011.
model DunningTenantAutomation {
  tenantId                  String   @id @map("tenant_id") @db.Uuid
  runMode                   String   @default("SEMI") @map("run_mode") @db.VarChar(12)
  jobHourUtc                Int?     @map("job_hour_utc")
  ianaTimezone              String   @default("Europe/Berlin") @map("iana_timezone") @db.VarChar(64)
  federalStateCode          String?  @map("federal_state_code") @db.VarChar(4)
  paymentTermDayKind        String   @default("CALENDAR") @map("payment_term_day_kind") @db.VarChar(16)
  preferredDunningChannel   String   @default("EMAIL") @map("preferred_dunning_channel") @db.VarChar(10)
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("dunning_tenant_automation")
}

/// Anmeldekonto pro Mandant; E-Mail nur innerhalb des Mandanten eindeutig (Multi-Tenant-Scope).
model User {
  tenantId     String   @map("tenant_id") @db.Uuid
  id           String   @db.Uuid
  emailNorm    String   @map("email_norm")
  passwordHash String   @map("password_hash")
  role         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  @@id([tenantId, id])
  @@unique([tenantId, emailNorm])
  @@map("users")
}

/// Einmal-Link Passwort-Reset (SHA-256-Digest des Klartext-Tokens, kein Klartext in DB).
model PasswordResetChallenge {
  id          String    @id @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenDigest String    @unique @map("token_digest")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId, userId])
  @@map("password_reset_challenges")
}

/// Export-Preflight-Lauf (`POST /exports`); bei Postgres in einer Tx mit dem zugehörigen `audit_events`-Eintrag geschrieben.
model ExportRunRow {
  tenantId          String   @map("tenant_id") @db.Uuid
  id                String   @db.Uuid
  entityType        String   @map("entity_type")
  entityId          String   @map("entity_id") @db.Uuid
  format            String
  status            String
  validationErrors  Json     @map("validation_errors")
  createdAt         DateTime @map("created_at")
  createdBy         String   @map("created_by") @db.Uuid

  @@id([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("export_runs")
}

/// Persistente Audit-Zeile; Lesepfad API bleibt DSGVO-minimiert (kein before/after in GET).
model AuditEvent {
  id          String   @id @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id") @db.Uuid
  action      String
  timestamp   DateTime
  actorUserId String   @map("actor_user_id") @db.Uuid
  reason      String?
  beforeState Json?    @map("before_state")
  afterState  Json?    @map("after_state")

  @@index([tenantId, timestamp])
  @@map("audit_events")
}
