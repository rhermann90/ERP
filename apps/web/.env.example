# Öffentliche Vite-Variablen (nur VITE_* werden an den Client gebundelt)
VITE_API_BASE_URL=http://localhost:3000

# Optional: GitHub „blob/<branch>“-URL ohne trailing slash — klickbare Doku-Links auf „Finanz (Vorbereitung)“
# VITE_REPO_DOCS_BASE=https://github.com/ORG/ERP/blob/main
# Optional: OpenAPI info.version zum Release — bei Abweichung zu x-erp-openapi-contract-version auf FIN-4-Pfaden nur console.warn
# VITE_EXPECTED_OPENAPI_CONTRACT_VERSION=1.29.2-fin5-xrechnung-regime-xml
